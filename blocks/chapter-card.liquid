<article class="block-chapter-card" {{ block.shopify_attributes }}>
  {%- if block.settings.link != blank -%}<a href="{{ block.settings.link }}">{%- endif -%}

  <div class="block-chapter-card__media">
    {%- if block.settings.image != blank -%}
      {% render 'image-responsive', image: block.settings.image, alt: block.settings.title, sizes: '(max-width: 680px) 100vw, 33vw' %}
    {%- elsif block.settings.demo_image != blank -%}
      {%- comment -%} Demo fallback (shipped in /assets) until an image is set. {%- endcomment -%}
      <img src="{{ block.settings.demo_image | asset_url }}" alt="{{ block.settings.title | escape }}" width="1800" height="1029" loading="lazy" decoding="async">
    {%- else -%}
      <div class="block-chapter-card__placeholder" aria-hidden="true"></div>
    {%- endif -%}
  </div>

  {%- if block.settings.chapter != blank -%}
    <div class="block-chapter-card__chapter">{{ block.settings.chapter | escape }}</div>
  {%- endif -%}
  {%- if block.settings.title != blank -%}
    <h3 class="block-chapter-card__title">{{ block.settings.title | escape }}</h3>
  {%- endif -%}
  {%- if block.settings.paragraph != blank -%}
    <p class="block-chapter-card__paragraph">{{ block.settings.paragraph }}</p>
  {%- endif -%}
  {%- if block.settings.link != blank and block.settings.link_label != blank -%}
    <span class="cta block-chapter-card__cta">{{ block.settings.link_label | escape }}</span>
  {%- endif -%}

  {%- if block.settings.link != blank -%}</a>{%- endif -%}
</article>

{% stylesheet %}
.block-chapter-card { text-align: left; display: flex; flex-direction: column; }
.block-chapter-card a { display: contents; }

.block-chapter-card__media {
  aspect-ratio: 3/4; overflow: hidden; background: var(--ink-faint-20);
  position: relative; margin-bottom: 28px;
}
.block-chapter-card__media img { width: 100%; height: 100%; object-fit: cover; transition: transform 1000ms var(--ease-long); }
.block-chapter-card:hover .block-chapter-card__media img { transform: scale(1.04); }
.block-chapter-card__placeholder { width: 100%; height: 100%; background: var(--ink-faint-20); }

.block-chapter-card__chapter {
  font-family: var(--sans); font-weight: 400; font-size: 11px; letter-spacing: 0.22em;
  text-transform: uppercase; color: var(--muted); margin-bottom: 16px;
}
.block-chapter-card__title {
  font-family: var(--serif); font-style: italic; font-size: clamp(22px, 1.8vw, 28px);
  line-height: 1.2; font-weight: 400; margin: 0 0 10px; color: var(--ink);
}
.block-chapter-card__paragraph {
  font-family: var(--sans); font-weight: 300; font-size: 15px; line-height: 1.65;
  color: var(--ink-soft); max-width: 330px; margin: 0 0 14px;
}
.block-chapter-card__cta { font-size: 10px; color: var(--ink-soft); }
{% endstylesheet %}

{% schema %}
{
  "name": "Chapter card",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image (3:4 portrait)" },
    { "type": "text", "id": "demo_image", "label": "Demo image (asset filename)", "info": "e.g. collection-aurora.webp — used only when no image is chosen." },
    { "type": "text", "id": "chapter", "label": "Chapter label", "default": "Capítulo 01" },
    { "type": "text", "id": "title", "label": "Title", "default": "Aurora 202 Rosa" },
    { "type": "richtext", "id": "paragraph", "label": "Paragraph", "default": "<p>Una historia.</p>" },
    { "type": "url", "id": "link", "label": "Link" },
    { "type": "text", "id": "link_label", "label": "CTA label", "default": "Descubrir" }
  ]
}
{% endschema %}
