{%- liquid
  assign style = block.settings.style | default: 'italic-display'
-%}
<blockquote class="block-quote block-quote--{{ style }}" {{ block.shopify_attributes }}>
  <p>{{ block.settings.text }}</p>
  {%- if block.settings.attribution != blank -%}
    <cite>— {{ block.settings.attribution | escape }}</cite>
  {%- endif -%}
</blockquote>

{% stylesheet %}
.block-quote { margin: 0 auto; max-width: 820px; text-align: center; }
.block-quote--italic-display p {
  font-family: var(--serif); font-style: italic; font-weight: 400;
  font-size: clamp(22px, 1.8vw, 28px); line-height: 1.2; letter-spacing: -0.005em;
  margin: 0; color: var(--ink);
}
.block-quote--inline p {
  font-family: var(--sans); font-style: normal; font-weight: 300;
  font-size: 15px; line-height: 1.65; color: var(--ink-soft);
  margin: 0;
}
.block-quote cite {
  display: block; margin-top: 12px;
  font-family: var(--sans); font-style: normal; font-weight: 400;
  font-size: 11px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--muted);
}
.block-quote em { font-style: italic; }
{% endstylesheet %}

{% schema %}
{
  "name": "Quote",
  "settings": [
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Una herencia que <em>trasciende</em> generaciones.</p>"
    },
    { "type": "text", "id": "attribution", "label": "Attribution (optional)" },
    {
      "type": "select",
      "id": "style",
      "label": "Style",
      "options": [
        { "value": "italic-display", "label": "Italic display" },
        { "value": "inline", "label": "Inline" }
      ],
      "default": "italic-display"
    }
  ]
}
{% endschema %}
