{%- liquid
  assign aspect = block.settings.aspect_ratio | default: 'natural'
  assign img_class = 'block-image block-image--' | append: aspect
  if block.settings.hover_zoom
    assign img_class = img_class | append: ' block-image--hover-zoom'
  endif
-%}
<div class="{{ img_class }}" {{ block.shopify_attributes }}>
  {%- if block.settings.link != blank -%}<a href="{{ block.settings.link }}">{%- endif -%}
  {%- if block.settings.image != blank -%}
    {% render 'image-responsive', image: block.settings.image, alt: block.settings.alt, sizes: '(max-width: 680px) 100vw, 50vw' %}
  {%- else -%}
    <div class="block-image__placeholder" aria-hidden="true"></div>
  {%- endif -%}
  {%- if block.settings.link != blank -%}</a>{%- endif -%}
</div>

{% stylesheet %}
.block-image { overflow: hidden; background: var(--ink-faint-20); position: relative; }
.block-image img { width: 100%; height: 100%; object-fit: cover; transition: transform 1000ms var(--ease-long); }
.block-image--natural { aspect-ratio: auto; }
.block-image--square { aspect-ratio: 1/1; }
.block-image--portrait { aspect-ratio: 3/4; }
.block-image--landscape { aspect-ratio: 4/3; }
.block-image--wide { aspect-ratio: 16/9; }
.block-image--hover-zoom:hover img { transform: scale(1.04); }
.block-image__placeholder { padding-top: 75%; background: var(--ink-faint-20); }
{% endstylesheet %}

{% schema %}
{
  "name": "Image",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "alt", "label": "Alt text override" },
    {
      "type": "select",
      "id": "aspect_ratio",
      "label": "Aspect ratio",
      "options": [
        { "value": "natural", "label": "Natural" },
        { "value": "square", "label": "Square (1:1)" },
        { "value": "portrait", "label": "Portrait (3:4)" },
        { "value": "landscape", "label": "Landscape (4:3)" },
        { "value": "wide", "label": "Wide (16:9)" }
      ],
      "default": "portrait"
    },
    { "type": "url", "id": "link", "label": "Link (optional)" },
    { "type": "checkbox", "id": "hover_zoom", "label": "Zoom on hover", "default": true }
  ]
}
{% endschema %}
