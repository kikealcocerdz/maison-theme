<aside class="mega" id="megaMenu" aria-hidden="true">
  <div class="mega-inner">
    {%- for block in section.blocks -%}
      {%- case block.type -%}

      {%- when 'column' -%}
        {%- assign linklist = linklists[block.settings.menu] -%}
        <div {{ block.shopify_attributes }}>
          <h3>{{ block.settings.heading | escape }}</h3>
          <ul>
            {%- for link in linklist.links -%}
              <li><a href="{{ link.url }}"><span>{{ link.title }}</span><span aria-hidden="true">→</span></a></li>
            {%- endfor -%}
          </ul>
        </div>

      {%- when 'feature_card' -%}
        <div class="mega-card" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            {% render 'image-responsive', image: block.settings.image, alt: block.settings.image.alt, sizes: '(max-width: 1100px) 100vw, 25vw' %}
          {%- endif -%}
          <p>{{ block.settings.text | escape }}</p>
          {%- if block.settings.link != blank -%}
            <a class="cta" href="{{ block.settings.link }}">{{ block.settings.link_label | default: 'Descubrir' | escape }} <span aria-hidden="true">→</span></a>
          {%- endif -%}
        </div>

      {%- endcase -%}
    {%- endfor -%}
  </div>
</aside>

{% stylesheet %}
.mega {
  position: fixed;
  z-index: 70;
  top: var(--header-h);
  left: 0;
  right: 0;
  background: var(--paper);
  color: var(--ink);
  border-bottom: 0.5px solid var(--rule);
  transform: translate3d(0, -112%, 0);
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
  transition: transform 720ms var(--ease-long), opacity 420ms var(--ease), visibility 0s linear 720ms;
  box-shadow: 0 20px 60px rgba(15, 26, 46, 0.06);
}

.menu-open .mega {
  transform: translate3d(0, 0, 0);
  opacity: 1;
  visibility: visible;
  pointer-events: auto;
  transition: transform 720ms var(--ease-long), opacity 420ms var(--ease), visibility 0s linear 0s;
}

.mega-inner {
  width: var(--content);
  margin: 0 auto;
  padding: 58px 0 68px;
  display: grid;
  grid-template-columns: repeat(4, 1fr) 1.25fr;
  gap: 48px;
}

.mega h3 {
  font-family: var(--serif);
  font-size: 30px;
  font-weight: 400;
  margin: 0 0 24px;
}

.mega ul {
  list-style: none;
  margin: 0;
  padding: 0;
  display: grid;
  gap: 14px;
}

.mega li a {
  font-size: 12px;
  letter-spacing: 0.08em;
  color: var(--ink-soft);
  display: flex;
  justify-content: space-between;
  gap: 18px;
  padding-bottom: 7px;
  border-bottom: 0.5px solid transparent;
}

.mega li a:hover { border-color: var(--rule); }

.mega-card {
  background: var(--ink-faint-20);
  padding: 14px;
}

.mega-card img {
  width: 100%;
  height: 200px;
  object-fit: cover;
}

.mega-card p {
  font-family: var(--serif);
  font-size: 28px;
  line-height: 1;
  margin: 20px 0 18px;
  color: var(--ink);
}

@media (max-width: 1100px) {
  .mega-inner { grid-template-columns: 1fr; padding: 32px 0; }
}

@media (max-width: 680px) {
  .mega { top: var(--header-h); }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Mega menu",
  "max_blocks": 6,
  "blocks": [
    {
      "type": "column",
      "name": "Column",
      "limit": 4,
      "settings": [
        { "type": "text", "id": "heading", "label": "Column heading", "default": "Producto" },
        { "type": "link_list", "id": "menu", "label": "Menu" }
      ]
    },
    {
      "type": "feature_card",
      "name": "Feature card",
      "limit": 1,
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "text", "label": "Text", "default": "Una casa histórica vuelve a latir." },
        { "type": "url", "id": "link", "label": "Link" },
        { "type": "text", "id": "link_label", "label": "Link label", "default": "Descubrir historia" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Mega menu",
      "blocks": [
        { "type": "column" },
        { "type": "column" },
        { "type": "column" },
        { "type": "column" },
        { "type": "feature_card" }
      ]
    }
  ],
  "enabled_on": { "groups": ["header"] }
}
{% endschema %}
