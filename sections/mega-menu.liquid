<aside class="mega" id="megaMenu" aria-hidden="true">
  <div class="mega-inner">
    {%- for block in section.blocks -%}
      {%- case block.type -%}

      {%- when 'column' -%}
        {%- assign linklist = linklists[block.settings.menu] -%}
        <div {{ block.shopify_attributes }}>
          <h3>{{ block.settings.heading | escape }}</h3>
          <ul>
            {%- if linklist.links.size > 0 -%}
              {%- for link in linklist.links -%}
                <li><a href="{{ link.url }}"><span>{{ link.title }}</span></a></li>
              {%- endfor -%}
            {%- elsif block.settings.items != blank -%}
              {%- comment -%} Demo items: one per line, "Label | meta | url" (meta + url optional). {%- endcomment -%}
              {%- assign lines = block.settings.items | strip | newline_to_br | split: '<br />' -%}
              {%- for line in lines -%}
                {%- assign row = line | strip -%}
                {%- if row == blank -%}{%- continue -%}{%- endif -%}
                {%- assign parts = row | split: '|' -%}
                {%- assign label = parts[0] | strip -%}
                {%- assign meta = '' -%}
                {%- assign url = '' -%}
                {%- if parts.size > 1 -%}{%- assign meta = parts[1] | strip -%}{%- endif -%}
                {%- if parts.size > 2 -%}{%- assign url = parts[2] | strip -%}{%- endif -%}
                {%- if url != blank -%}
                  <li><a href="{{ url }}"><span>{{ label | escape }}</span>{%- if meta != blank -%}<span aria-hidden="true">{{ meta | escape }}</span>{%- endif -%}</a></li>
                {%- else -%}
                  <li><span>{{ label | escape }}</span>{%- if meta != blank -%}<span aria-hidden="true">{{ meta | escape }}</span>{%- endif -%}</li>
                {%- endif -%}
              {%- endfor -%}
            {%- endif -%}
          </ul>
        </div>

      {%- when 'feature_card' -%}
        <div class="mega-card" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            {% render 'image-responsive', image: block.settings.image, alt: block.settings.image.alt, sizes: '(max-width: 1100px) 100vw, 25vw' %}
          {%- else -%}
            {%- comment -%} Demo fallback (shipped in /assets) until an image is set. {%- endcomment -%}
            <img src="{{ 'craft.webp' | asset_url }}" alt="{{ block.settings.text | escape }}" width="1450" height="1800" loading="lazy" decoding="async">
          {%- endif -%}
          <p>{{ block.settings.text | escape }}</p>
          {%- if block.settings.link != blank -%}
            <a class="cta" href="{{ block.settings.link }}">{{ block.settings.link_label | default: 'Descubrir' | escape }} <span aria-hidden="true">→</span></a>
          {%- endif -%}
        </div>

      {%- endcase -%}
    {%- endfor -%}
  </div>
</aside>

{% stylesheet %}
.mega {
  position: fixed;
  z-index: 70;
  top: var(--header-h);
  left: 0;
  right: 0;
  background: var(--paper);
  color: var(--ink);
  border-bottom: 0.5px solid var(--rule);
  transform: translate3d(0, -112%, 0);
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
  transition: transform 720ms var(--ease-long), opacity 420ms var(--ease), visibility 0s linear 720ms;
  box-shadow: 0 20px 60px rgba(15, 26, 46, 0.06);
}

.menu-open .mega {
  transform: translate3d(0, 0, 0);
  opacity: 1;
  visibility: visible;
  pointer-events: auto;
  transition: transform 720ms var(--ease-long), opacity 420ms var(--ease), visibility 0s linear 0s;
}

.mega-inner {
  width: min(90vw, 1760px);
  margin: 0 auto;
  padding: 58px 0 68px;
  display: grid;
  grid-template-columns: repeat(3, 1fr) 1.25fr;
  gap: 48px;
}

.mega h3 {
  font-family: var(--serif);
  font-size: 30px;
  font-weight: 400;
  margin: 0 0 24px;
}

.mega ul {
  list-style: none;
  margin: 0;
  padding: 0;
  display: grid;
  gap: 14px;
}

.mega li {
  font-size: 12px;
  letter-spacing: 0.08em;
  color: var(--ink-soft);
  display: flex;
  justify-content: space-between;
  gap: 18px;
  padding-bottom: 7px;
  border-bottom: 0.5px solid transparent;
}

.mega li:hover { border-color: var(--rule); }

.mega li a {
  display: flex;
  justify-content: space-between;
  gap: 18px;
  width: 100%;
  color: inherit;
}

.mega-card {
  background: var(--ink-faint-20);
  padding: 14px;
}

.mega-card img {
  width: 100%;
  height: 200px;
  object-fit: cover;
}

.mega-card p {
  font-family: var(--serif);
  font-size: 28px;
  line-height: 1;
  margin: 20px 0 18px;
  color: var(--ink);
}

@media (max-width: 1100px) {
  .mega-inner { grid-template-columns: 1fr; padding: 32px 0; }
}

@media (max-width: 680px) {
  .mega { top: var(--header-h); }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Mega menu",
  "max_blocks": 6,
  "blocks": [
    {
      "type": "column",
      "name": "Column",
      "limit": 4,
      "settings": [
        { "type": "text", "id": "heading", "label": "Column heading", "default": "Producto" },
        { "type": "link_list", "id": "menu", "label": "Menu" },
        { "type": "textarea", "id": "items", "label": "Items (one per line: 'Label | meta')", "info": "Used when no menu is selected. The optional text after | is the right-side meta label; omit it for no second column." }
      ]
    },
    {
      "type": "feature_card",
      "name": "Feature card",
      "limit": 1,
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "text", "label": "Text", "default": "Una casa histórica vuelve a latir." },
        { "type": "url", "id": "link", "label": "Link" },
        { "type": "text", "id": "link_label", "label": "Link label", "default": "Descubrir historia" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Mega menu",
      "blocks": [
        { "type": "column" },
        { "type": "column" },
        { "type": "column" },
        { "type": "column" },
        { "type": "feature_card" }
      ]
    }
  ],
  "enabled_on": { "groups": ["header"] }
}
{% endschema %}
