{%- comment -%}
  Slide-out mini-cart. Rendered once via header-group. Hydrated from /cart.js;
  intercepts add-to-cart forms anywhere on the page and opens on success.
{%- endcomment -%}

<div class="cart-drawer" id="cartDrawer" aria-hidden="true"
  data-money-format="{{ shop.money_format | escape }}">
  <div class="cart-drawer__overlay" data-cart-close></div>
  <aside class="cart-drawer__panel" role="dialog" aria-modal="true" aria-label="{{ 'general.cart.label' | t | default: 'Cesta' }}">
    <header class="cart-drawer__head">
      <span class="cart-drawer__title">
        {{ 'general.cart.label' | t | default: 'Cesta' }}
        <span class="cart-drawer__count" data-cart-count>({{ cart.item_count }})</span>
      </span>
      <button class="cart-drawer__close" type="button" data-cart-close aria-label="{{ 'general.accessibility.close' | t | default: 'Cerrar' }}">
        {% render 'icon-close' %}
      </button>
    </header>

    <div class="cart-drawer__body" data-cart-body aria-live="polite"></div>

    <div class="cart-drawer__empty" data-cart-empty hidden>
      <p>{{ 'sections.cart.empty' | t | default: 'Tu cesta está vacía.' }}</p>
      <a class="ghost-btn" href="{{ routes.all_products_collection_url }}" data-cart-close>Descubrir colecciones</a>
    </div>

    <footer class="cart-drawer__foot" data-cart-foot hidden>
      <div class="cart-drawer__subtotal">
        <span>{{ 'sections.cart.subtotal' | t | default: 'Subtotal' }}</span>
        <span data-cart-subtotal></span>
      </div>
      <p class="cart-drawer__note">{{ 'sections.cart.taxes_note' | t | default: 'Gastos de envío e impuestos calculados en el checkout.' }}</p>
      <a class="ghost-btn cart-drawer__checkout" href="/checkout">{{ 'sections.cart.checkout' | t | default: 'Finalizar compra' }}</a>
      <a class="cart-drawer__viewcart cta" href="{{ routes.cart_url }}">{{ 'sections.cart.view' | t | default: 'Ver cesta' }}</a>
    </footer>
  </aside>
</div>

{% stylesheet %}
.cart-drawer {
  position: fixed;
  inset: 0;
  z-index: 120;
  visibility: hidden;
  pointer-events: none;
}
.cart-open .cart-drawer { visibility: visible; pointer-events: auto; }

.cart-drawer__overlay {
  position: absolute;
  inset: 0;
  background: rgba(15, 26, 46, 0.32);
  opacity: 0;
  transition: opacity 420ms var(--ease);
}
.cart-open .cart-drawer__overlay { opacity: 1; }

.cart-drawer__panel {
  position: absolute;
  top: 0;
  right: 0;
  height: 100%;
  width: min(440px, 100vw);
  background: var(--paper);
  color: var(--ink);
  display: flex;
  flex-direction: column;
  transform: translate3d(100%, 0, 0);
  transition: transform 560ms var(--ease-long);
  box-shadow: -20px 0 60px rgba(15, 26, 46, 0.10);
}
.cart-open .cart-drawer__panel { transform: translate3d(0, 0, 0); }

.cart-drawer__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 26px 28px;
  border-bottom: 0.5px solid var(--rule);
}
.cart-drawer__title {
  font-family: var(--serif);
  font-size: 24px;
  font-weight: 400;
}
.cart-drawer__count { color: var(--muted); font-size: 16px; }
.cart-drawer__close { display: grid; place-items: center; width: 32px; height: 32px; color: var(--ink); }

.cart-drawer__body { flex: 1 1 auto; overflow-y: auto; padding: 8px 28px; }

.cart-line {
  display: grid;
  grid-template-columns: 72px 1fr auto;
  gap: 16px;
  padding: 22px 0;
  border-bottom: 0.5px solid var(--rule);
}
.cart-line__media { width: 72px; height: 90px; object-fit: cover; background: var(--ink-faint-20); }
.cart-line__info { display: flex; flex-direction: column; gap: 6px; min-width: 0; }
.cart-line__title { font-family: var(--serif); font-size: 16px; line-height: 1.2; }
.cart-line__variant { font-size: 11px; letter-spacing: 0.04em; color: var(--muted); }
.cart-line__qty {
  margin-top: 6px;
  display: inline-flex;
  align-items: center;
  border: 0.5px solid var(--rule);
  width: max-content;
}
.cart-line__qty button {
  width: 30px; height: 30px;
  font-size: 14px; color: var(--ink);
  display: grid; place-items: center;
}
.cart-line__qty button:disabled { opacity: 0.3; }
.cart-line__qty span { min-width: 30px; text-align: center; font-size: 12px; }
.cart-line__right { display: flex; flex-direction: column; align-items: flex-end; justify-content: space-between; }
.cart-line__price { font-size: 13px; }
.cart-line__remove { font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--muted); border-bottom: 0.5px solid transparent; }
.cart-line__remove:hover { color: var(--ink); border-color: var(--ink); }

.cart-drawer__empty { padding: 60px 28px; text-align: center; display: flex; flex-direction: column; gap: 22px; align-items: center; }
.cart-drawer__empty p { font-family: var(--serif); font-size: 22px; }

.cart-drawer__foot { padding: 24px 28px 30px; border-top: 0.5px solid var(--rule); }
.cart-drawer__subtotal { display: flex; justify-content: space-between; font-size: 13px; letter-spacing: 0.08em; text-transform: uppercase; }
.cart-drawer__note { font-size: 11px; color: var(--muted); margin: 10px 0 18px; }
.cart-drawer__checkout { width: 100%; }
.cart-drawer__viewcart { display: block; text-align: center; margin-top: 16px; }

.cart-drawer.is-loading .cart-drawer__panel { cursor: progress; }
.cart-drawer.is-loading .cart-drawer__body { opacity: 0.55; transition: opacity 160ms var(--ease); }

@media (prefers-reduced-motion: reduce) {
  .cart-drawer__panel, .cart-drawer__overlay { transition: none; }
}
{% endstylesheet %}

{% javascript %}
(function () {
  if (window.__cartDrawerInit) return;
  window.__cartDrawerInit = true;

  var drawer = document.getElementById('cartDrawer');
  if (!drawer) return;

  var body = document.body;
  var bodyEl = drawer.querySelector('[data-cart-body]');
  var emptyEl = drawer.querySelector('[data-cart-empty]');
  var footEl = drawer.querySelector('[data-cart-foot]');
  var subtotalEl = drawer.querySelector('[data-cart-subtotal]');
  var countEls = function () { return document.querySelectorAll('[data-cart-count],[data-cart-count-badge]'); };
  var LB = String.fromCharCode(123), RB = String.fromCharCode(125);
  var moneyFormat = drawer.getAttribute('data-money-format') || ('$' + LB + LB + 'amount' + RB + RB);

  function formatMoney(cents) {
    var value = (cents / 100);
    function withDelimiters(num, precision, thousands, decimal) {
      thousands = thousands || ','; decimal = decimal || '.';
      num = (num || 0).toFixed(precision);
      var parts = num.split('.');
      var intPart = parts[0].replace(/(\d)(?=(\d\d\d)+(?!\d))/g, '$1' + thousands);
      return parts[1] ? intPart + decimal + parts[1] : intPart;
    }
    return moneyFormat.replace(/\{\{\s*(\w+)\s*\}\}/g, function (_, key) {
      switch (key) {
        case 'amount': return withDelimiters(value, 2, ',', '.');
        case 'amount_no_decimals': return withDelimiters(value, 0, ',', '.');
        case 'amount_with_comma_separator': return withDelimiters(value, 2, '.', ',');
        case 'amount_no_decimals_with_comma_separator': return withDelimiters(value, 0, '.', ',');
        case 'amount_with_space_separator': return withDelimiters(value, 2, ' ', ',');
        case 'amount_no_decimals_with_space_separator': return withDelimiters(value, 0, ' ', '');
        default: return withDelimiters(value, 2, ',', '.');
      }
    });
  }

  function esc(s) {
    return String(s == null ? '' : s)
      .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  function render(cart) {
    countEls().forEach(function (el) {
      el.textContent = el.hasAttribute('data-cart-count') ? '(' + cart.item_count + ')' : cart.item_count;
    });

    if (!cart.items || cart.items.length === 0) {
      bodyEl.innerHTML = '';
      emptyEl.hidden = false;
      footEl.hidden = true;
      return;
    }
    emptyEl.hidden = true;
    footEl.hidden = false;
    subtotalEl.textContent = formatMoney(cart.items_subtotal_price != null ? cart.items_subtotal_price : cart.total_price);

    bodyEl.innerHTML = cart.items.map(function (item) {
      var img = item.image ? item.image.replace(/(\.[a-zA-Z]+)(\?.*)?$/, '_160x$1$2') : '';
      var variant = (item.variant_title && item.variant_title !== 'Default Title') ? '<span class="cart-line__variant">' + esc(item.variant_title) + '</span>' : '';
      return '' +
        '<div class="cart-line" data-line-key="' + esc(item.key) + '">' +
          (img ? '<img class="cart-line__media" src="' + esc(img) + '" alt="" width="72" height="90" loading="lazy">' : '<span class="cart-line__media"></span>') +
          '<div class="cart-line__info">' +
            '<a class="cart-line__title" href="' + esc(item.url) + '">' + esc(item.product_title || item.title) + '</a>' +
            variant +
            '<span class="cart-line__qty">' +
              '<button type="button" data-qty-down aria-label="Restar">−</button>' +
              '<span>' + item.quantity + '</span>' +
              '<button type="button" data-qty-up aria-label="Sumar">+</button>' +
            '</span>' +
          '</div>' +
          '<div class="cart-line__right">' +
            '<span class="cart-line__price">' + formatMoney(item.final_line_price) + '</span>' +
            '<button type="button" class="cart-line__remove" data-line-remove>Eliminar</button>' +
          '</div>' +
        '</div>';
    }).join('');
  }

  function setLoading(on) { drawer.classList.toggle('is-loading', !!on); }

  function fetchCart() {
    return fetch('/cart.js', { headers: { 'Accept': 'application/json' } }).then(function (r) { return r.json(); });
  }

  function refresh() {
    return fetchCart().then(render);
  }

  function open() {
    body.classList.add('cart-open');
    drawer.setAttribute('aria-hidden', 'false');
    refresh();
  }
  function close() {
    body.classList.remove('cart-open');
    drawer.setAttribute('aria-hidden', 'true');
  }

  function change(key, qty) {
    setLoading(true);
    fetch('/cart/change.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify({ id: key, quantity: qty })
    }).then(function (r) { return r.json(); }).then(function (cart) {
      render(cart);
    }).catch(function () {}).then(function () { setLoading(false); });
  }

  // Delegate clicks inside the drawer.
  drawer.addEventListener('click', function (e) {
    if (e.target.closest('[data-cart-close]')) { close(); return; }
    var line = e.target.closest('.cart-line');
    if (!line) return;
    var key = line.getAttribute('data-line-key');
    var qtySpan = line.querySelector('.cart-line__qty span');
    var current = qtySpan ? parseInt(qtySpan.textContent, 10) : 1;
    if (e.target.closest('[data-line-remove]')) { change(key, 0); }
    else if (e.target.closest('[data-qty-up]')) { change(key, current + 1); }
    else if (e.target.closest('[data-qty-down]')) { change(key, Math.max(0, current - 1)); }
  });

  // Header cart toggle(s).
  document.addEventListener('click', function (e) {
    var toggle = e.target.closest('[data-cart-toggle]');
    if (toggle) { e.preventDefault(); open(); }
  });

  // Esc closes.
  window.addEventListener('keydown', function (e) {
    if (e.key === 'Escape' && body.classList.contains('cart-open')) close();
  });

  // Intercept add-to-cart form submits anywhere on the page.
  document.addEventListener('submit', function (e) {
    var form = e.target;
    if (!(form instanceof HTMLFormElement)) return;
    var action = form.getAttribute('action') || '';
    var isAdd = action.indexOf('/cart/add') !== -1 || form.querySelector('[name="add"]');
    if (!isAdd) return;
    if (action.indexOf('/cart/add') === -1 && !form.querySelector('[name="id"]')) return;
    e.preventDefault();
    var btn = form.querySelector('[type="submit"],[name="add"]');
    if (btn) btn.setAttribute('disabled', 'disabled');
    setLoading(true);
    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
      body: new FormData(form)
    }).then(function (r) { return r.json(); }).then(function () {
      return refresh();
    }).then(function () {
      open();
    }).catch(function () {}).then(function () {
      if (btn) btn.removeAttribute('disabled');
      setLoading(false);
    });
  });

  // Initial count sync.
  refresh();
})();
{% endjavascript %}

{% schema %}
{
  "name": "Cart drawer",
  "settings": [],
  "enabled_on": { "groups": ["header"] }
}
{% endschema %}
