<section class="placeholder-section">
  <div class="shell">
    <span class="eyebrow">Homepage placeholder</span>
    <h1 class="display">{{ shop.name }}</h1>
    <p>The Maison homepage will be built in Plan 2. Header and footer are functional.</p>
  </div>
</section>

{% stylesheet %}
.placeholder-section {
  padding: calc(var(--header-h) + 120px) 0 200px;
  text-align: center;
}

.placeholder-section .eyebrow { display: block; margin-bottom: 16px; }

.placeholder-section h1 { font-size: clamp(48px, 6vw, 96px); margin: 0 0 24px; }

.placeholder-section p {
  font-family: var(--sans);
  font-weight: 300;
  font-size: 16px;
  color: var(--ink-soft);
  max-width: 480px;
  margin: 0 auto;
}
{% endstylesheet %}

{% schema %}
{
  "name": "Page placeholder",
  "settings": [],
  "presets": [{ "name": "Page placeholder" }]
}
{% endschema %}
