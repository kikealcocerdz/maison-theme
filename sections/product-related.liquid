{%- comment -%}
  Related products row — reused twice on the PDP ("Completa la mesa" same-collection,
  "Te puede interesar" cross-sell). Auto-fills from a chosen collection; falls back
  to demo `product` blocks before the catalog migrates (CLAUDE.md §7).
{%- endcomment -%}
{%- liquid
  assign source = collections[section.settings.collection]
  assign limit = section.settings.product_limit | default: 5
  assign auto = false
  if source != blank and source.products.size > 0
    assign auto = true
  endif
-%}
<section class="product-related reveal" data-section-id="{{ section.id }}">
  {%- if section.settings.heading != blank -%}<h2>{{ section.settings.heading | escape }}</h2>{%- endif -%}
  <div class="related-grid">
    {%- if auto -%}
      {%- for product in source.products limit: limit -%}
        {%- liquid
          assign r_img1 = product.featured_image | image_url: width: 720
          assign r_img2 = product.images[1] | image_url: width: 720
          assign r_w = product.featured_image.width | default: 1000
          assign r_h = product.featured_image.height | default: 1250
          assign r_price = product.price | money
          assign r_meta = product.collections.first.title | default: product.type
          assign r_new = 0
          if product.tags contains 'novedad' or product.tags contains 'new'
            assign r_new = 1
          endif
        -%}
        {% render 'related-card',
          card_url: product.url, title: product.title, price: r_price, meta: r_meta,
          img1: r_img1, img2: r_img2, img_w: r_w, img_h: r_h,
          badge: r_new, data_price: product.price, data_new: r_new %}
      {%- endfor -%}
    {%- else -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'product' -%}
          {%- liquid
            assign d_img1 = block.settings.demo_image | asset_url
            assign d_img2 = ''
            if block.settings.demo_image_2 != blank
              assign d_img2 = block.settings.demo_image_2 | asset_url
            endif
          -%}
          {% render 'related-card',
            card_url: block.settings.link, title: block.settings.demo_title,
            price: block.settings.demo_price, meta: block.settings.demo_meta,
            img1: d_img1, img2: d_img2, badge: block.settings.badge,
            data_price: block.settings.data_price, data_new: block.settings.data_new %}
        {%- endif -%}
      {%- endfor -%}
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
.product-related { width: var(--content); margin: 0 auto; padding: 0 0 10vh; }
.product-related + .product-related { padding-top: 2vh; }
.product-related h2 { font-family: var(--serif); font-weight: 400; font-size: clamp(30px, 3vw, 48px); line-height: 1; margin: 0 0 34px; color: var(--ink); }
.product-related .related-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 18px; }
.product-related .related-grid .product-info { grid-template-columns: 1fr; gap: 6px; margin-top: 13px; }
.product-related .related-grid .price { text-align: left; }
@media (max-width: 1180px) { .product-related .related-grid { grid-template-columns: repeat(3, 1fr); } }
@media (max-width: 720px) { .product-related .related-grid { grid-template-columns: repeat(2, 1fr); gap: 28px 12px; } }
{% endstylesheet %}

{% schema %}
{
  "name": "Related products",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Completa la mesa" },
    { "type": "collection", "id": "collection", "label": "Collection (auto-fill — overrides demo blocks)" },
    { "type": "range", "id": "product_limit", "label": "Products shown", "min": 3, "max": 6, "step": 1, "default": 5 }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Demo product",
      "settings": [
        { "type": "url", "id": "link", "label": "Link" },
        { "type": "text", "id": "demo_title", "label": "Title" },
        { "type": "text", "id": "demo_price", "label": "Price (e.g. 92 €)" },
        { "type": "text", "id": "demo_meta", "label": "Meta line" },
        { "type": "text", "id": "demo_image", "label": "Image (asset filename)" },
        { "type": "text", "id": "demo_image_2", "label": "Hover image (asset filename)" },
        { "type": "checkbox", "id": "badge", "label": "Show 'Novedad' badge", "default": false },
        { "type": "number", "id": "data_price", "label": "Sort price (number)" },
        { "type": "number", "id": "data_new", "label": "Is new (1/0)" },
        { "type": "text", "id": "data_type", "label": "Product type slug" }
      ]
    }
  ],
  "presets": [{ "name": "Related products" }]
}
{% endschema %}
