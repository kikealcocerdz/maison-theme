<section class="section-lede reveal" data-section-id="{{ section.id }}" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="shell">
    {%- content_for 'blocks' -%}
  </div>
</section>

{% stylesheet %}
.section-lede {
  text-align: center;
  margin: 0 auto;
}
.section-lede .shell {
  max-width: 820px;
}
{% endstylesheet %}

{% schema %}
{
  "name": "Pull quote",
  "blocks": [
    { "type": "quote" },
    { "type": "text" }
  ],
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top (px)",
      "min": 0,
      "max": 400,
      "step": 10,
      "default": 200
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom (px)",
      "min": 0,
      "max": 400,
      "step": 10,
      "default": 200
    }
  ],
  "presets": [
    {
      "name": "Pull quote",
      "blocks": [
        {
          "type": "quote",
          "settings": {
            "text": "<p>Una herencia que <em>trasciende</em> generaciones.<br>Una forma de vivir la mesa que <em>evoluciona</em> con el tiempo.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
