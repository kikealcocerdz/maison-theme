<section class="section-lede {% if section.settings.soft_bg %}soft-bg{% endif %} reveal" data-section-id="{{ section.id }}">
  <div class="shell">
    {%- content_for 'blocks' -%}
  </div>
</section>

{% stylesheet %}
.section-lede {
  text-align: center;
  margin: 0 auto;
  padding: 20vh 0;
}
.section-lede .shell {
  max-width: 820px;
  margin: 0 auto;
}
{% endstylesheet %}

{% schema %}
{
  "name": "Pull quote",
  "blocks": [
    { "type": "quote" },
    { "type": "text" }
  ],
  "settings": [
    { "type": "checkbox", "id": "soft_bg", "label": "Soft background", "default": false }
  ],
  "presets": [
    {
      "name": "Pull quote",
      "blocks": [
        {
          "type": "quote",
          "settings": {
            "text": "<p>Una herencia que <em>trasciende</em> generaciones.<br>Una forma de vivir la mesa que <em>evoluciona</em> con el tiempo.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
