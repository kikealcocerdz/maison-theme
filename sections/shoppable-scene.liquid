{%- liquid
  assign products = section.blocks | where: 'type', 'product'
-%}
<section class="table-scene scene-redesign hairline" id="tables-{{ section.id }}" data-section-id="{{ section.id }}">
  <div class="scene-layout">
    {%- if section.settings.heading != blank or section.settings.eyebrow != blank or section.settings.description != blank -%}
      <div class="scene-copy reveal">
        {%- if section.settings.eyebrow != blank -%}<span class="eyebrow">{{ section.settings.eyebrow | escape }}</span>{%- endif -%}
        {%- if section.settings.heading != blank -%}<h2>{{ section.settings.heading | escape }}</h2>{%- endif -%}
        {%- if section.settings.description != blank -%}<p>{{ section.settings.description }}</p>{%- endif -%}
      </div>
    {%- endif -%}

    <div class="scene-interactive reveal">
      <div class="scene-left-image">
        {%- if section.settings.image != blank -%}
          {% render 'image-responsive', image: section.settings.image, alt: section.settings.image.alt, sizes: '(max-width: 1000px) 100vw, 55vw' %}
        {%- else -%}
          {%- comment -%} Demo fallback (shipped in /assets) until a scene image is set. {%- endcomment -%}
          <img src="{{ 'scene-left-tableware.webp' | asset_url }}" alt="{{ section.settings.heading | escape }}" width="2400" height="1792" loading="lazy" decoding="async">
        {%- endif -%}
        {%- for block in products -%}
          {%- liquid
            assign p = all_products[block.settings.product]
            assign p_name = block.settings.demo_title
            if p != blank
              assign p_name = p.title
            endif
          -%}
          <button class="scene-hotspot{% if forloop.first %} active{% endif %}" style="left: {{ block.settings.hotspot_x }}%; top: {{ block.settings.hotspot_y }}%;" data-scene-hotspot="{{ forloop.index0 }}" aria-label="Ver {{ p_name | escape }}" {{ block.shopify_attributes }}></button>
        {%- endfor -%}
      </div>

      <aside class="scene-product-view" aria-live="polite">
        <button class="scene-nav prev" data-scene-prev type="button" aria-label="{{ 'general.accessibility.previous' | t }}">&lsaquo;</button>
        <div class="scene-product-inner" data-scene-product></div>
        <button class="scene-nav next" data-scene-next type="button" aria-label="{{ 'general.accessibility.next' | t }}">&rsaquo;</button>
        <div class="scene-dots" data-scene-dots></div>
      </aside>
    </div>

    {%- if section.settings.cta_label != blank and section.settings.cta_link != blank -%}
      <div class="center reveal"><a href="{{ section.settings.cta_link }}" class="ghost-btn">{{ section.settings.cta_label | escape }}</a></div>
    {%- endif -%}

    {%- comment -%} Product data consumed by JS to render the right-side panel. {%- endcomment -%}
    <script type="application/json" data-scene-data>
      [
        {%- for block in products -%}
          {%- liquid
            assign p = all_products[block.settings.product]
            assign p_name = block.settings.demo_title
            assign p_meta = block.settings.meta_line
            assign p_price = block.settings.demo_price
            assign p_url = block.settings.link
            assign p_img = ''
            if block.settings.demo_image != blank
              assign p_img = block.settings.demo_image | asset_url
            endif
            if p != blank
              assign p_name = p.title
              assign p_url = p.url
              assign p_price = p.price | money
              if p.featured_image != blank
                assign p_img = p.featured_image | image_url: width: 840
              endif
            endif
          -%}
          {
            "name": {{ p_name | default: '' | json }},
            "meta": {{ p_meta | default: '' | json }},
            "price": {{ p_price | default: '' | json }},
            "img": {{ p_img | default: '' | json }},
            "url": {{ p_url | default: '#' | json }}
          }{%- unless forloop.last -%},{%- endunless -%}
        {%- endfor -%}
      ]
    </script>
  </div>
</section>

{% stylesheet %}
.table-scene.scene-redesign { padding: 132px 0 180px; background: var(--paper); }
.scene-redesign .scene-layout { width: var(--content); margin: 0 auto; display: block; }
.scene-redesign .scene-copy { text-align: center; margin: 0 auto 46px; max-width: 740px; }
.scene-redesign .scene-copy h2 {
  font-family: var(--serif); font-size: clamp(28px, 2.6vw, 40px); line-height: 1.12;
  font-weight: 400; margin: 0 0 16px;
}
.scene-redesign .scene-copy p {
  font-size: 12px; line-height: 1.85; color: var(--ink-soft); max-width: 580px; margin: 0 auto;
}
.scene-interactive {
  display: grid; grid-template-columns: 1.08fr 0.92fr;
  gap: min(5vw, 72px); align-items: stretch;
}
.scene-left-image {
  position: relative; min-height: 620px;
  background: var(--ink-faint-20); overflow: hidden;
}
.scene-left-image img { width: 100%; height: 100%; object-fit: cover; transition: transform 1100ms var(--ease-long); }
.scene-left-image:hover img { transform: scale(1.025); }
.scene-hotspot {
  position: absolute; width: 18px; height: 18px;
  border: 0.5px solid var(--ink); background: var(--paper);
  border-radius: 999px; box-shadow: 0 0 0 9px rgba(255, 255, 255, 0.48);
  transform: translate(-50%, -50%);
  transition: transform 260ms var(--ease), background 260ms var(--ease), color 260ms var(--ease);
}
.scene-hotspot:hover, .scene-hotspot.active { transform: translate(-50%, -50%) scale(1.24); background: var(--ink); color: var(--paper); }
.scene-hotspot::after { content: ""; position: absolute; inset: 6px; border-radius: 999px; background: currentColor; }
.scene-product-view {
  position: relative; min-height: 620px; background: var(--paper);
  display: flex; align-items: center; justify-content: center;
  border-top: 0.5px solid var(--rule); border-bottom: 0.5px solid var(--rule);
}
.scene-product-inner { text-align: center; width: 100%; padding: 46px 72px; }
.scene-product-inner img {
  height: min(48vh, 420px); width: 100%; object-fit: contain; margin: 0 auto 34px;
  transition: transform 700ms var(--ease-long), opacity 360ms var(--ease);
}
.scene-product-inner h3 {
  font-family: var(--serif); font-weight: 400; font-size: 26px; line-height: 1.12;
  margin: 0 0 7px; color: var(--ink);
}
.scene-product-inner p {
  font-size: 10px; letter-spacing: 0.22em; text-transform: uppercase;
  color: var(--muted); margin: 0 0 10px;
}
.scene-product-inner .scene-price { font-size: 13px; color: var(--ink); }
.scene-nav {
  position: absolute; top: 50%; transform: translateY(-50%);
  width: 42px; height: 42px; display: grid; place-items: center;
  color: var(--ink); font-size: 28px; line-height: 1; opacity: 0.82;
  transition: opacity 220ms var(--ease), transform 220ms var(--ease);
  background: transparent; border: 0; cursor: pointer;
}
.scene-nav:hover { opacity: 1; transform: translateY(-50%) scale(1.06); }
.scene-nav.prev { left: 18px; }
.scene-nav.next { right: 18px; }
.scene-dots {
  position: absolute; left: 0; right: 0; bottom: 28px;
  display: flex; justify-content: center; gap: 8px;
}
.scene-dots span { width: 26px; height: 1px; background: rgba(15, 26, 46, 0.22); transition: background 220ms var(--ease), width 220ms var(--ease); }
.scene-dots span.active { background: var(--ink); width: 36px; }

.scene-redesign .center { text-align: center; margin-top: 72px; }

.scene-image-open { display: block; width: 100%; background: transparent; border: 0; padding: 0; margin: 0 auto 34px; cursor: zoom-in; }
.scene-image-open img { height: min(48vh, 420px) !important; margin: 0 auto !important; }
.scene-actions { display: grid; gap: 10px; margin: 26px auto 0; width: min(100%, 300px); }
.ghost-btn.small-cart { height: 42px; padding: 0 18px; font-size: 10px; letter-spacing: 0.18em; width: 100%; }
.ghost-btn.small-cart.alt { background: transparent; color: var(--ink); }

.quick-image-lightbox {
  position: fixed; inset: 0; z-index: 9999; background: rgba(15, 26, 46, 0.82);
  display: grid; place-items: center; opacity: 0; transition: opacity 260ms var(--ease);
}
.quick-image-lightbox.is-open { opacity: 1; }
.quick-image-lightbox img { max-width: 82vw; max-height: 82vh; object-fit: contain; background: var(--paper); padding: min(4vw, 42px); }
.quick-image-lightbox button { position: absolute; right: 34px; top: 24px; color: var(--paper); font-family: var(--serif); font-size: 42px; line-height: 1; background: transparent; border: 0; cursor: pointer; }

@media (max-width: 1000px) {
  .scene-interactive { grid-template-columns: 1fr; }
  .scene-left-image, .scene-product-view { min-height: 520px; }
  .scene-product-inner img { height: 320px; }
}
@media (max-width: 680px) {
  .table-scene.scene-redesign { padding: 74px 0 130px; }
  .scene-left-image, .scene-product-view { min-height: 420px; }
  .scene-product-inner { padding: 38px 48px; }
  .scene-product-inner img { height: 260px; }
  .scene-nav.prev { left: 6px; }
  .scene-nav.next { right: 6px; }
  .scene-redesign .center { margin-top: 58px; }
  .scene-actions { width: 100%; }
}
@media (prefers-reduced-motion: reduce) {
  .scene-left-image img, .scene-hotspot, .scene-product-inner img { transition: none; }
}
{% endstylesheet %}

{% javascript %}
(function () {
  const ADD = 'Añadir al carrito';
  const BUY_TABLE = 'Comprar mesa completa';

  document.querySelectorAll('.scene-redesign:not([data-init])').forEach(initScene);

  function initScene(root) {
    root.dataset.init = '1';
    const dataEl = root.querySelector('[data-scene-data]');
    const panel = root.querySelector('[data-scene-product]');
    const dots = root.querySelector('[data-scene-dots]');
    const hotspots = [...root.querySelectorAll('[data-scene-hotspot]')];
    if (!dataEl || !panel || !dots) return;

    let items = [];
    try { items = JSON.parse(dataEl.textContent.trim()); } catch (e) { items = []; }
    if (!items.length) return;

    let current = 0;

    function render() {
      const p = items[current];
      const imgHtml = p.img
        ? `<a class="scene-image-open" href="${p.url || '#'}" data-scene-open><img src="${p.img}" alt="${p.name || ''}"></a>`
        : '';
      panel.innerHTML =
        imgHtml +
        (p.meta ? `<p>${p.meta}</p>` : '') +
        `<h3>${p.name || ''}</h3>` +
        (p.price ? `<span class="scene-price">${p.price}</span>` : '') +
        `<div class="scene-actions">
           <button class="ghost-btn small-cart" type="button">${ADD}</button>
           <button class="ghost-btn small-cart alt" type="button">${BUY_TABLE}</button>
         </div>`;
      dots.innerHTML = items.map((_, i) => `<span class="${i === current ? 'active' : ''}"></span>`).join('');
      hotspots.forEach((h, i) => h.classList.toggle('active', i === current));
    }

    function set(i) { current = (i + items.length) % items.length; render(); }

    hotspots.forEach(h => h.addEventListener('click', () => set(Number(h.dataset.sceneHotspot))));
    root.querySelector('[data-scene-prev]')?.addEventListener('click', () => set(current - 1));
    root.querySelector('[data-scene-next]')?.addEventListener('click', () => set(current + 1));

    dots.addEventListener('click', e => {
      const span = e.target.closest('span');
      if (!span) return;
      set([...dots.children].indexOf(span));
    });

    // Fullscreen image lightbox
    panel.addEventListener('click', e => {
      const open = e.target.closest('[data-scene-open]');
      if (!open) return;
      e.preventDefault();
      const img = open.querySelector('img');
      if (!img) return;
      const overlay = document.createElement('div');
      overlay.className = 'quick-image-lightbox';
      overlay.innerHTML = `<button type="button" aria-label="Cerrar">×</button><img src="${img.src}" alt="${img.alt}">`;
      document.body.appendChild(overlay);
      requestAnimationFrame(() => overlay.classList.add('is-open'));
      const close = () => { overlay.classList.remove('is-open'); setTimeout(() => overlay.remove(), 240); };
      overlay.addEventListener('click', ev => { if (ev.target === overlay || ev.target.tagName === 'BUTTON') close(); });
      document.addEventListener('keydown', function esc(ev) { if (ev.key === 'Escape') { close(); document.removeEventListener('keydown', esc); } });
    });

    render();
  }

  document.addEventListener('shopify:section:load', (e) => {
    e.target.querySelectorAll('.scene-redesign:not([data-init])').forEach(initScene);
  });
})();
{% endjavascript %}

{% schema %}
{
  "name": "Shoppable scene",
  "max_blocks": 8,
  "blocks": [
    {
      "type": "product",
      "name": "Hotspot product",
      "settings": [
        { "type": "product", "id": "product", "label": "Product" },
        { "type": "text", "id": "meta_line", "label": "Collection label (e.g. 'Aurora Collection')" },
        { "type": "url", "id": "link", "label": "Link (used for demo / image open)" },
        { "type": "range", "id": "hotspot_x", "label": "Hotspot X position (%)", "min": 2, "max": 98, "step": 1, "default": 50 },
        { "type": "range", "id": "hotspot_y", "label": "Hotspot Y position (%)", "min": 2, "max": 98, "step": 1, "default": 50 },
        { "type": "header", "content": "Demo (when no product selected)" },
        { "type": "text", "id": "demo_image", "label": "Demo image (asset filename)", "info": "e.g. aurora_202_plato.png" },
        { "type": "text", "id": "demo_title", "label": "Demo title" },
        { "type": "text", "id": "demo_price", "label": "Demo price", "default": "Consultar" }
      ]
    }
  ],
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Nuestras mesas" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Una escena, cada pieza." },
    { "type": "richtext", "id": "description", "label": "Description" },
    { "type": "image_picker", "id": "image", "label": "Scene image (left side)" },
    { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Descubre nuestras mesas" },
    { "type": "url", "id": "cta_link", "label": "CTA link" }
  ],
  "presets": [
    {
      "name": "Shoppable scene",
      "blocks": [
        { "type": "product", "settings": { "hotspot_x": 32, "hotspot_y": 42 } },
        { "type": "product", "settings": { "hotspot_x": 57, "hotspot_y": 51 } },
        { "type": "product", "settings": { "hotspot_x": 71, "hotspot_y": 34 } },
        { "type": "product", "settings": { "hotspot_x": 43, "hotspot_y": 67 } },
        { "type": "product", "settings": { "hotspot_x": 79, "hotspot_y": 61 } }
      ]
    }
  ]
}
{% endschema %}
