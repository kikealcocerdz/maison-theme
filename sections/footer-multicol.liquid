<footer class="site-footer" data-section-id="{{ section.id }}">
  <div class="footer-grid">

    <div class="footer-logo">
      {%- if section.settings.logo != blank -%}
        <img src="{{ section.settings.logo | image_url: width: 200 }}" alt="{{ section.settings.logo_alt | default: shop.name | escape }}" width="88" height="auto" loading="lazy">
      {%- elsif settings.logo != blank -%}
        <img src="{{ settings.logo | image_url: width: 200 }}" alt="{{ settings.logo_alt | default: shop.name | escape }}" width="88" height="auto" loading="lazy">
      {%- endif -%}
      {%- if section.settings.tagline != blank -%}
        <p>{{ section.settings.tagline }}</p>
      {%- endif -%}
    </div>

    {%- for block in section.blocks -%}
      {%- case block.type -%}

      {%- when 'column' -%}
        {%- assign linklist = linklists[block.settings.menu] -%}
        <div {{ block.shopify_attributes }}>
          <h4>{{ block.settings.heading | escape }}</h4>
          {%- for link in linklist.links -%}
            <a href="{{ link.url }}">{{ link.title }}</a>
          {%- endfor -%}
        </div>

      {%- when 'text_column' -%}
        <div {{ block.shopify_attributes }}>
          <h4>{{ block.settings.heading | escape }}</h4>
          {{ block.settings.content }}
        </div>

      {%- endcase -%}
    {%- endfor -%}

  </div>

  <div class="footer-bottom">
    <span>{{ 'general.footer.copyright' | t: year: 'now' | date: '%Y', shop_name: shop.name }}</span>
    {%- if section.settings.tagline_bottom != blank -%}<span>{{ section.settings.tagline_bottom }}</span>{%- endif -%}
  </div>
</footer>

{% stylesheet %}
.site-footer {
  padding: 78px 0 44px;
  border-top: 0.5px solid var(--rule);
  background: var(--paper);
}

.footer-grid {
  width: var(--content);
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1.2fr repeat(3, 1fr);
  gap: 48px;
}

.footer-logo img {
  width: 88px;
  margin-bottom: 24px;
}

.footer-logo p {
  font-family: var(--serif);
  font-size: 34px;
  line-height: 1;
  margin: 0;
  color: var(--ink);
}

.footer-grid h4 {
  font-size: 10px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  margin: 0 0 18px;
}

.footer-grid a,
.footer-grid span {
  display: block;
  font-size: 12px;
  color: var(--ink-soft);
  margin-bottom: 10px;
}

.footer-bottom {
  width: var(--content);
  margin: 60px auto 0;
  display: flex;
  justify-content: space-between;
  font-size: 10px;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--muted);
}

@media (max-width: 1100px) {
  .footer-grid { grid-template-columns: 1fr 1fr; }
}

@media (max-width: 680px) {
  .footer-grid { grid-template-columns: 1fr; }
  .footer-bottom { display: grid; gap: 12px; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Footer logo (overrides theme setting)" },
    { "type": "text", "id": "logo_alt", "label": "Logo alt text" },
    { "type": "textarea", "id": "tagline", "label": "Tagline under logo", "default": "La Cartuja\nde Sevilla" },
    { "type": "text", "id": "tagline_bottom", "label": "Tagline bottom right", "default": "Hecho en España. Editado con calma." }
  ],
  "max_blocks": 6,
  "blocks": [
    {
      "type": "column",
      "name": "Menu column",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Shop" },
        { "type": "link_list", "id": "menu", "label": "Menu" }
      ]
    },
    {
      "type": "text_column",
      "name": "Text column",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Contact" },
        { "type": "richtext", "id": "content", "label": "Content", "default": "<p>Customer support<br>Newsletter<br>ES / EN</p>" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer multicolumn",
      "blocks": [
        { "type": "column", "settings": { "heading": "Comprar" } },
        { "type": "column", "settings": { "heading": "La casa" } },
        { "type": "text_column", "settings": { "heading": "Contacto" } }
      ]
    }
  ],
  "enabled_on": { "groups": ["footer"] }
}
{% endschema %}
